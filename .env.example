# ── Database ──────────────────────────────────────────────────────────────────
# Added automatically by the Railway Postgres plugin.
DATABASE_URL=postgresql://user:pass@host:5432/openproject

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=replace_with_128_char_hex_string

# Set to your Railway public domain after first deploy (no trailing slash)
OPENPROJECT_HOST__NAME=your-app.up.railway.app

# ── Pre-set in railway.toml (no action needed) ────────────────────────────────
PORT=8080
OPENPROJECT_WEB_PORT=8080
RAILS_ENV=production
OPENPROJECT_HTTPS=true
IMAP_ENABLED=false

# ── Email (optional) ──────────────────────────────────────────────────────────
# EMAIL_DELIVERY_METHOD=smtp
# SMTP_ADDRESS=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER_NAME=resend
# SMTP_PASSWORD=your-api-key
# SMTP_DOMAIN=yourdomain.com
# SMTP_AUTHENTICATION=plain
# SMTP_ENABLE_STARTTLS_AUTO=true

# ── Object storage (optional, recommended for production) ─────────────────────
# OPENPROJECT_ATTACHMENTS__STORAGE=fog
# FOG_PROVIDER=AWS
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION=ap-south-1
# FOG_DIRECTORY=your-bucket-name
