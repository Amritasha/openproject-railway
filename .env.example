# ── Database ──────────────────────────────────────────────────────────────────
# Add the Railway Postgres plugin; it auto-sets DATABASE_URL.
DATABASE_URL=postgresql://user:pass@host:5432/openproject

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY_BASE=replace_with_128_char_hex_string
RAILS_ENV=production

# Set to your Railway-generated public domain (no trailing slash)
OPENPROJECT_HOST__NAME=your-project.up.railway.app
OPENPROJECT_HTTPS=true

# ── Mail (optional) ───────────────────────────────────────────────────────────
# EMAIL_DELIVERY_METHOD=smtp
# SMTP_ADDRESS=smtp.example.com
# SMTP_PORT=587
# SMTP_USER_NAME=user@example.com
# SMTP_PASSWORD=secret
# SMTP_DOMAIN=example.com
